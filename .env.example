# hermes-zello-plugin — example environment
#
# Copy to .env and fill in. .env is gitignored.
# Production deployment sets these via sops on the host (see
# HERMES-ZELLO-PLAN.md §6.3); this file is for local dev / integration
# tests against a real Zello developer account.

# ── Required ────────────────────────────────────────────────────────

# Issuer ID from the Zello developer console (https://developers.zello.com).
ZELLO_ISSUER=

# Path to the RSA private key (PEM) that pairs with the issuer.
# Suggested local path; .gitignored.
ZELLO_PRIVATE_KEY_PATH=./private.key

# Zello account this bot logs in as.
ZELLO_USERNAME=
ZELLO_PASSWORD=

# Dedicated channel to join. Create it in the developer console first.
ZELLO_CHANNEL=

# ── Optional ────────────────────────────────────────────────────────

# Comma-separated Zello usernames allowed to address the bot. Unset =
# only the bot account itself can talk to it (effectively muted).
ZELLO_ALLOWED_USERS=

# Dev-only: bypass the allow-list entirely.
ZELLO_ALLOW_ALL_USERS=false

# Channel for cron / notification delivery. Defaults to ZELLO_CHANNEL.
ZELLO_HOME_CHANNEL=

# Utterance aggregator window: how long after a stream_stop before
# flushing the aggregated PTT to hermes as one MessageType.VOICE event.
# Phone-app PTT caps at ~60s, so back-to-back streams from the same
# user within this window are concatenated. Default 2 seconds.
ZELLO_AGGREGATOR_WINDOW_S=2

# Hard ceiling on aggregator hold time before forced flush, regardless
# of new inbound streams. Default 300 seconds (5 minutes).
ZELLO_MAX_UTTERANCE_S=300
